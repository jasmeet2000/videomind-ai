# =============================================================================
# VideoMind AI — Environment Variables
# Copy this file to .env and fill in your values.
# All defaults shown here are suitable for local Docker Compose development.
# =============================================================================

# --- Application ---
APP_NAME=VideoMind AI
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://videomind:videomind@localhost:5432/videomind

# --- Vector Database (Qdrant) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=videomind

# --- LLM (Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3
OLLAMA_TIMEOUT_SECONDS=120

# --- Embedding Model ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu

# --- Speech-to-Text (Whisper) ---
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=auto

# --- Video Processing ---
DATA_DIR=./data
MAX_VIDEO_SIZE_MB=500
FRAME_SAMPLE_RATE_FPS=1
FFMPEG_PATH=ffmpeg

# --- OCR ---
OCR_ENGINE=paddleocr
OCR_CONFIDENCE_THRESHOLD=0.7

# --- Retrieval ---
DENSE_RETRIEVAL_TOP_K=10
RERANK_TOP_K=5
HYBRID_ALPHA=0.7
