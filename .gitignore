htmlcov/

# --- Environment ---
.env
!.env.example

# --- Project Data (never commit video files or logs) ---
data/
logs/

# --- Model Cache (large binary files) ---
models/
*.gguf
*.bin
*.safetensors

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Docker ---
*.override.yml

# --- Testing ---
.pytest_cache/
test_output/

# --- Docs build ---
docs/_build/
site/
